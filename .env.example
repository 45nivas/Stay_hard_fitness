# Local Development Environment Variables
DEBUG=True
SECRET_KEY=your-secret-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Local PostgreSQL database URL (if using docker compose for db)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/gym_db

# Production Environment Variables (Set these on Render)
# DEBUG=False
# SECRET_KEY=your-production-secret-key
# DATABASE_URL=postgres://... (Neon/Supabase/Render Postgres URL)

